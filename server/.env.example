# Server Environment Variables
# Copy this file to .env and fill in real values

# ── Database ──────────────────────────────────────────────────
MONGODB_URI=mongodb+srv://<user>:<password>@cluster0.mongodb.net/golf-charity?retryWrites=true&w=majority

# ── JWT ───────────────────────────────────────────────────────
JWT_SECRET=REPLACE_WITH_LONG_RANDOM_SECRET_32_CHARS
JWT_REFRESH_SECRET=REPLACE_WITH_ANOTHER_LONG_RANDOM_SECRET

# ── Stripe ────────────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_test_REPLACE_ME
STRIPE_WEBHOOK_SECRET=whsec_REPLACE_ME
STRIPE_PRICE_MONTHLY=price_REPLACE_ME
STRIPE_PRICE_YEARLY=price_REPLACE_ME

# ── Cloudinary ────────────────────────────────────────────────
CLOUDINARY_CLOUD_NAME=REPLACE_ME
CLOUDINARY_API_KEY=REPLACE_ME
CLOUDINARY_API_SECRET=REPLACE_ME

# ── Email (Nodemailer SMTP) ───────────────────────────────────
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=your@gmail.com
EMAIL_PASS=your_app_password

# ── App ───────────────────────────────────────────────────────
NODE_ENV=development
PORT=5000
CLIENT_URL=http://localhost:5173
